{
  "entities": {
    "Prediction": {
      "title": "Prediction",
      "description": "A sports betting prediction generated by the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the prediction" },
        "userId": { "type": "string", "description": "ID of the user who requested the analysis" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation" },
        "matchName": { "type": "string", "description": "Name of the match (e.g., Real Madrid vs Man City)" },
        "date": { "type": "string", "description": "Date of the match" },
        "sport": { "type": "string", "description": "Sport category" },
        "bestMarket": { "type": "string", "description": "The recommended betting market" },
        "selection": { "type": "string", "description": "The specific selection within the market" },
        "bookmaker": { "type": "string", "description": "Recommended bookmaker" },
        "odds": { "type": "number", "description": "Market odds" },
        "edgePercent": { "type": "number", "description": "Calculated edge percentage" },
        "confidence": { "type": "integer", "description": "Confidence level 1-10" },
        "analysisText": { "type": "string", "description": "Detailed AI analysis" },
        "userContext": { "type": "string", "description": "Additional context provided by the user" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"], "description": "Current status of the bet" }
      },
      "required": ["userId", "matchName", "bestMarket", "selection", "odds", "edgePercent", "confidence", "status"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Collection of all betting predictions."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    }
  }
}
