# ═══════════════════════════════════════════════════════════════
# COCO VIP - AI-DRIVEN SPORTS BETTING ANALYSIS
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# STEP 1: THE ODDS API (Real-time Odds)
# ───────────────────────────────────────────────────────────────
# Get your API key at: https://the-odds-api.com/
# Used for: Real odds from Bet365, Pinnacle, Betfair
ODDS_API_KEY=your_odds_api_key_here

# ───────────────────────────────────────────────────────────────
# STEP 2 & 3: OPENROUTER (AI Agents)
# ───────────────────────────────────────────────────────────────
# Get your API key at: https://openrouter.ai/
# Used for: Perplexity (Research) and DeepSeek (Quant Analysis)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ───────────────────────────────────────────────────────────────
# LEGACY: API-Sports (kept for daily automatic picks only)
# ───────────────────────────────────────────────────────────────
# Get your API key at: https://api-sports.io/
# Used ONLY by: /api/generate-daily-picks.js (NOT modified)
SPORTS_API_KEY=your_api_sports_key_here

# Balldontlie API for NBA (FREE - required for NBA picks)
# Get your API key at: https://balldontlie.io/
BALLDONTLIE_API_KEY=your_balldontlie_api_key_here

# ───────────────────────────────────────────────────────────────
# GOOGLE SHEETS INTEGRATION (History Database)
# ───────────────────────────────────────────────────────────────
# Create a Google Cloud Project and Service Account:
# 1. Go to console.cloud.google.com
# 2. Create new project or select existing
# 3. Enable Google Sheets API
# 4. Create Service Account
# 5. Download JSON key file
# 6. Share your Google Sheet with the service account email (Editor access)

# The Google Sheet ID from the URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID_HERE/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Service account email (from JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com

# Private key from JSON key file (copy the entire key including \n characters)
# IMPORTANT: Keep the quotes and \\n for newlines
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Client-side variable for "Abrir Sheets" button
VITE_GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# ───────────────────────────────────────────────────────────────
# LEGACY GOOGLE SHEETS (Apps Script - for daily picks cache)
# ───────────────────────────────────────────────────────────────
# URL from Apps Script deployment - must support these actions:
# - ?action=getCache&date=YYYY-MM-DD&sport=football
# - ?action=writeCache&data=[...]
# - ?action=writeAnalysis&data={...}
# - ?action=getMetadata
# - ?action=clearOldCache&before_date=YYYY-MM-DD
GOOGLE_SHEETS_URL=

# ───────────────────────────────────────────────────────────────
# SUPABASE CONFIGURATION (Backend)
# ───────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Vite client-side variables (must be prefixed with VITE_)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ───────────────────────────────────────────────────────────────
# APP CONFIGURATION
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
