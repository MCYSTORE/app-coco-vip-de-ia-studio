# Sports API (API-Sports - funciona para Football, Basketball, Baseball)
# Get your API key at: https://api-sports.io/
SPORTS_API_KEY=your_api_sports_key_here

# OpenRouter Free for AI Analysis (optional)
# Get your API key at: https://openrouter.ai/
OPENROUTERFREE_API_KEY=

# Google Sheets Integration (for Scanner results)
# URL from Apps Script deployment
GOOGLE_SHEETS_URL=

# App Configuration
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
